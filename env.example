# =============================================================================
# Serve Volunteering Service - Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# --- Server ---
SERVER_PORT=9090

# --- Database ---
DB_URL=jdbc:postgresql://localhost:5432/ev-vriddhi
DB_USERNAME=postgres
DB_PASSWORD=

# HikariCP Connection Pool
HIKARI_MAX_POOL=10
HIKARI_MIN_IDLE=5
HIKARI_IDLE_TIMEOUT=300000
HIKARI_CONN_TIMEOUT=20000
HIKARI_MAX_LIFETIME=1200000

# --- JPA ---
JPA_DDL_AUTO=validate
JPA_SHOW_SQL=false

# --- Keycloak ---
KEYCLOAK_ISSUER_URI=http://localhost:8080/realms/sunbird-serve
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=sunbird-serve
KEYCLOAK_ADMIN_CLIENT_ID=serve-backend
KEYCLOAK_ADMIN_CLIENT_SECRET=

# --- External Services ---
RC_SERVICE_URL=http://localhost:8081/api/v1/

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*

# --- Email ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# --- Logging ---
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO
LOG_LEVEL_HTTP_CLIENT=DEBUG
LOG_FILE=appLog.log

# --- Swagger / OpenAPI ---
SPRINGDOC_ENABLED=true

# --- User Cache ---
USER_CACHE_REFRESH_MS=60000

# --- Error Handling ---
INCLUDE_EXCEPTION=false
INCLUDE_STACKTRACE=never
